---
const title = "Đặt vé tàu cao tốc | Đất Mỏ Travel";
const description = "Đặt vé tàu cao tốc Ao Tiên, Vũng Đục đi Cô Tô, Quan Lạn, Minh Châu. Thanh toán trực tuyến, xác nhận nhanh.";

const routes = [
  { value: "ao-tien-co-to", label: "Ao Tiên → Cô Tô", price: 280000, childPrice: 140000, reverse: "co-to-ao-tien" },
  { value: "co-to-ao-tien", label: "Cô Tô → Ao Tiên", price: 280000, childPrice: 140000, reverse: "ao-tien-co-to" },
  { value: "ao-tien-quan-lan", label: "Ao Tiên → Quan Lạn", price: 250000, childPrice: 125000, reverse: "quan-lan-ao-tien" },
  { value: "quan-lan-ao-tien", label: "Quan Lạn → Ao Tiên", price: 250000, childPrice: 125000, reverse: "ao-tien-quan-lan" },
  { value: "ao-tien-minh-chau", label: "Ao Tiên → Minh Châu", price: 250000, childPrice: 125000, reverse: "minh-chau-ao-tien" },
  { value: "minh-chau-ao-tien", label: "Minh Châu → Ao Tiên", price: 250000, childPrice: 125000, reverse: "ao-tien-minh-chau" },
];

const today = new Date().toISOString().split('T')[0];
---

<!doctype html>
<html lang="vi">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href="https://booking.datmo.io.vn/" />

  <meta property="og:locale" content="vi_VN" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content="https://booking.datmo.io.vn/" />
  <meta property="og:site_name" content="Đất Mỏ Travel" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />

  <meta name="geo.region" content="VN-QN" />
  <meta name="geo.placename" content="Cẩm Phả, Quảng Ninh" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- Header -->
  <header class="site-header">
    <div class="container header-inner">
      <a class="brand" href="https://datmo.io.vn" aria-label="Trang chủ Datmo.io.vn">
        <div class="brand-badge"></div>
        <span>Đất Mỏ Travel</span>
      </a>
      <nav class="nav" aria-label="Điều hướng">
        <a href="https://datmo.io.vn/ve-tau-cao-toc/">Lịch tàu & giá</a>
        <a href="https://datmo.io.vn/lien-he/">Liên hệ</a>
      </nav>
    </div>
  </header>

  <main id="main">
    <!-- Hero -->
    <section class="hero">
      <div class="container">
        <div class="hero-content">
          <p class="kicker">⚡ Đặt vé trực tuyến</p>
          <h1>Đặt vé tàu cao tốc</h1>
          <p class="lead">Ao Tiên / Vũng Đục → Cô Tô, Quan Lạn, Minh Châu. Thanh toán chuyển khoản — xác nhận ngay.</p>
        </div>
      </div>
    </section>

    <!-- Booking Form -->
    <section class="container section">
      <div class="booking-card">
        <h2>Thông tin đặt vé</h2>
        <p class="small">Điền thông tin để đặt vé. Vé sẽ được xác nhận sau khi thanh toán.</p>

        <form id="booking-form" class="booking-grid">
          <!-- Trip Type -->
          <div class="form-field full-width trip-type-selector">
            <label class="field-label">Loại chuyến đi</label>
            <div class="trip-type-options">
              <label class="trip-option">
                <input type="radio" name="trip_type" value="one-way" checked />
                <span class="trip-pill">🚢 Một chiều</span>
              </label>
              <label class="trip-option">
                <input type="radio" name="trip_type" value="round-trip" />
                <span class="trip-pill">🔄 Khứ hồi</span>
              </label>
            </div>
          </div>

          <!-- Route -->
          <div class="form-field full-width">
            <label for="route" class="field-label">Tuyến đi *</label>
            <select id="route" name="route" required>
              <option value="">-- Chọn tuyến --</option>
              {routes.map(r => (
                <option value={r.value} data-adult-price={r.price} data-child-price={r.childPrice} data-reverse={r.reverse}>
                  {r.label} ({r.price.toLocaleString('vi-VN')}đ/người lớn)
                </option>
              ))}
            </select>
          </div>

          <!-- Outbound Date -->
          <div class="form-field">
            <label for="travel_date" class="field-label">Ngày đi *</label>
            <input type="date" id="travel_date" name="travel_date" required min={today} />
          </div>

          <!-- Outbound Time -->
          <div class="form-field">
            <label for="departure_time" class="field-label">Giờ khởi hành</label>
            <select id="departure_time" name="departure_time">
              <option value="">-- Chọn giờ --</option>
              <option value="07:30">07:30</option>
              <option value="08:00">08:00</option>
              <option value="08:30">08:30</option>
              <option value="13:00">13:00</option>
              <option value="13:30">13:30</option>
              <option value="14:00">14:00</option>
            </select>
          </div>

          <!-- Return Section -->
          <div class="return-section full-width" id="return-section" style="display: none;">
            <div class="return-divider"><span>↩ Chiều về</span></div>
            <div class="return-fields">
              <div class="form-field">
                <label for="return_date" class="field-label">Ngày về *</label>
                <input type="date" id="return_date" name="return_date" min={today} />
              </div>
              <div class="form-field">
                <label for="return_departure_time" class="field-label">Giờ khởi hành (về)</label>
                <select id="return_departure_time" name="return_departure_time">
                  <option value="">-- Chọn giờ --</option>
                  <option value="07:30">07:30</option>
                  <option value="08:00">08:00</option>
                  <option value="08:30">08:30</option>
                  <option value="13:00">13:00</option>
                  <option value="13:30">13:30</option>
                  <option value="14:00">14:00</option>
                </select>
              </div>
            </div>
          </div>

          <!-- Passengers -->
          <div class="form-field">
            <label for="adults" class="field-label">Người lớn *</label>
            <input type="number" id="adults" name="adults" min="1" max="20" value="1" required />
          </div>
          <div class="form-field">
            <label for="children" class="field-label">Trẻ em (dưới 6 tuổi)</label>
            <input type="number" id="children" name="children" min="0" max="10" value="0" />
          </div>

          <!-- Passenger Info -->
          <div class="form-field full-width">
            <label for="passenger_name" class="field-label">Họ tên người đặt *</label>
            <input type="text" id="passenger_name" name="passenger_name" required placeholder="Nguyễn Văn A" />
          </div>
          <div class="form-field">
            <label for="passenger_phone" class="field-label">Số điện thoại *</label>
            <input type="tel" id="passenger_phone" name="passenger_phone" required placeholder="0912 345 678" />
          </div>
          <div class="form-field">
            <label for="passenger_email" class="field-label">Email</label>
            <input type="email" id="passenger_email" name="passenger_email" placeholder="email@example.com" />
          </div>

          <!-- Price Display -->
          <div class="price-display full-width">
            <div class="price-row">
              <span class="price-label">Tổng cộng</span>
              <span class="price-amount" id="total-amount">0 đ</span>
            </div>
            <span class="price-breakdown" id="price-breakdown" style="display: none;"></span>
          </div>

          <button type="submit" class="btn primary full-width submit-btn" id="submit-btn">
            <span id="btn-text">Tiếp tục thanh toán</span>
            <svg class="spinner hidden" id="btn-spinner" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <circle cx="12" cy="12" r="10" stroke-dasharray="31.4" stroke-dashoffset="10" stroke-linecap="round"/>
            </svg>
          </button>

          <p id="booking-status" class="form-status full-width" role="status" aria-live="polite"></p>
        </form>
      </div>
    </section>

    <!-- Info Cards -->
    <section class="container section">
      <div class="info-grid">
        <div class="info-card">
          <div class="info-icon">🛡️</div>
          <h3>Thanh toán an toàn</h3>
          <p>Chuyển khoản ngân hàng — xác nhận vé trong 15 phút.</p>
        </div>
        <div class="info-card">
          <div class="info-icon">📱</div>
          <h3>Vé điện tử</h3>
          <p>Nhận mã vé ngay sau khi thanh toán, không cần in giấy.</p>
        </div>
        <div class="info-card">
          <div class="info-icon">☎️</div>
          <h3>Hỗ trợ 24/7</h3>
          <p>Hotline: <a href="tel:+84911321578">0911 321 578</a> — Zalo: <a href="https://zalo.me/911321578" rel="nofollow">Nhắn Zalo</a></p>
        </div>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="container footer-inner">
      <p>© {new Date().getFullYear()} <a href="https://datmo.io.vn">Datmo.io.vn</a> — Công ty CP Thương mại và Du lịch Đất Mỏ</p>
      <p>Hotline: <a href="tel:+84911321578">0911 321 578</a> · <a href="mailto:ctcpdulich.datmo@gmail.com">ctcpdulich.datmo@gmail.com</a></p>
    </div>
  </footer>

  <!-- Mobile CTA -->
  <div class="mobile-cta">
    <a class="mobile-cta-btn" href="tel:+84911321578" aria-label="Gọi ngay">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
        <path d="M21 16.5v3.25a1.25 1.25 0 0 1-1.37 1.24A18.8 18.8 0 0 1 3 4.37 1.25 1.25 0 0 1 4.24 3H7.5A1.25 1.25 0 0 1 8.75 4.1c.1.9.3 1.78.6 2.63a1.25 1.25 0 0 1-.28 1.31L7.9 9.2a15.5 15.5 0 0 0 6.9 6.9l1.16-1.17a1.25 1.25 0 0 1 1.31-.28c.85.3 1.73.5 2.63.6A1.25 1.25 0 0 1 21 16.5z"/>
      </svg>
    </a>
  </div>
</body>
</html>

<style>
  /* === Design Tokens === */
  :root {
    --bg: #f5fbff;
    --surface: #ecf7ff;
    --card: #ffffff;
    --text: #0f2a44;
    --muted: #4b6b8a;
    --brand: #06b6d4;
    --brand2: #3b82f6;
    --brand3: #a855f7;
    --border: rgba(15,42,68,.12);
    --shadow: 0 12px 30px rgba(15,42,68,.10);
    --radius: 18px;
    --container: 680px;
    --container-pad: 16px;
  }

  /* === Reset & Base === */
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;
    background:
      radial-gradient(900px 500px at 0% 0%, rgba(6,182,212,.2), transparent 60%),
      radial-gradient(700px 500px at 100% 0%, rgba(59,130,246,.18), transparent 55%),
      linear-gradient(180deg, #f5fbff 0%, #eef6ff 100%);
    color: var(--text);
    line-height: 1.65;
    min-height: 100vh;
  }
  a { color: var(--brand2); text-decoration: none; }
  a:hover { text-decoration: underline; }

  .container { max-width: var(--container); margin: 0 auto; padding: 0 var(--container-pad); }
  .section { padding: 0 0 32px; }
  .hidden { display: none !important; }

  /* === Header === */
  .site-header {
    position: sticky; top: 0; z-index: 20;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background: rgba(255,255,255,.8);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    display: flex; align-items: center; justify-content: space-between;
    gap: 12px; padding: 12px 0;
  }
  .brand { display: flex; align-items: center; gap: 10px; font-weight: 800; letter-spacing: .2px; color: var(--text); text-decoration: none; }
  .brand:hover { text-decoration: none; }
  .brand-badge {
    width: 34px; height: 34px; border-radius: 10px;
    background: linear-gradient(135deg, var(--brand), var(--brand2));
    box-shadow: var(--shadow);
  }
  .nav { display: flex; gap: 6px; align-items: center; }
  .nav a {
    display: inline-flex; align-items: center;
    padding: 8px 14px; border-radius: 10px;
    font-size: .9rem; font-weight: 500;
    color: var(--muted); white-space: nowrap;
    transition: background .2s;
  }
  .nav a:hover { background: rgba(6,182,212,.08); text-decoration: none; }

  /* === Hero === */
  .hero { padding: 32px 0 12px; }
  .hero-content { text-align: center; }
  .kicker { color: var(--brand); font-weight: 700; font-size: .9rem; letter-spacing: .3px; margin-bottom: 8px; }
  .hero h1 {
    font-size: clamp(26px, 5vw, 38px);
    line-height: 1.15;
    margin-bottom: 10px;
    background: linear-gradient(135deg, var(--text) 30%, var(--brand2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .lead { color: var(--muted); font-size: 1rem; max-width: 520px; margin: 0 auto; }

  /* === Booking Card === */
  .booking-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 28px 24px;
  }
  .booking-card h2 {
    font-size: 1.3rem; margin-bottom: 4px;
  }
  .booking-card > .small {
    color: var(--muted); font-size: .875rem; margin-bottom: 20px;
  }

  /* === Form Grid === */
  .booking-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .full-width { grid-column: 1 / -1; }

  .form-field { display: flex; flex-direction: column; gap: 6px; }
  .field-label { font-weight: 600; font-size: .875rem; color: var(--text); }

  .form-field input,
  .form-field select {
    padding: 11px 14px;
    border: 1.5px solid rgba(15,42,68,.15);
    border-radius: 12px;
    font: inherit; font-size: .95rem;
    background: #fff;
    color: var(--text);
    transition: border-color .2s, box-shadow .2s;
  }
  .form-field input:focus,
  .form-field select:focus {
    outline: none;
    border-color: var(--brand);
    box-shadow: 0 0 0 3px rgba(6,182,212,.15);
  }

  /* === Trip Type === */
  .trip-type-selector { margin-bottom: 4px; }
  .trip-type-options { display: flex; gap: 12px; }
  .trip-option { cursor: pointer; }
  .trip-option input { display: none; }
  .trip-pill {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 10px 20px;
    border: 1.5px solid rgba(15,42,68,.15);
    border-radius: 12px;
    font-weight: 500; font-size: .9rem;
    transition: all .2s;
    background: #fff;
  }
  .trip-option input:checked + .trip-pill {
    border-color: var(--brand);
    background: rgba(6,182,212,.08);
    color: var(--brand);
    box-shadow: 0 0 0 3px rgba(6,182,212,.1);
  }

  /* === Return Section === */
  .return-section {
    border-top: 2px dashed rgba(6,182,212,.3);
    padding-top: 16px;
    margin-top: 4px;
    animation: fadeIn .3s ease;
  }
  .return-divider {
    text-align: center; margin-bottom: 16px;
    font-weight: 600; font-size: .9rem; color: var(--brand);
  }
  .return-fields {
    display: grid; grid-template-columns: 1fr 1fr; gap: 16px;
  }

  /* === Price Display === */
  .price-display {
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    padding: 16px;
    background: linear-gradient(135deg, rgba(6,182,212,.06), rgba(59,130,246,.06));
    border: 1px solid rgba(6,182,212,.15);
    border-radius: 14px;
  }
  .price-row { display: flex; align-items: center; gap: 12px; }
  .price-label { font-weight: 600; color: var(--muted); }
  .price-amount { font-size: 1.5rem; font-weight: 800; color: var(--brand2); }
  .price-breakdown { font-size: .8rem; color: var(--muted); }

  /* === Button === */
  .btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    padding: 14px 24px;
    border-radius: 14px; border: none;
    font: inherit; font-weight: 700; font-size: 1.05rem;
    cursor: pointer;
    transition: all .2s;
  }
  .btn.primary {
    background: linear-gradient(135deg, var(--brand), var(--brand2));
    color: #fff;
    box-shadow: 0 8px 24px rgba(6,182,212,.3);
  }
  .btn.primary:hover {
    filter: brightness(1.06);
    box-shadow: 0 12px 32px rgba(6,182,212,.35);
    transform: translateY(-1px);
  }
  .btn.primary:active { transform: translateY(0); }
  .btn.primary:disabled {
    opacity: .7; cursor: not-allowed;
    filter: none; transform: none;
  }
  .submit-btn { width: 100%; min-height: 52px; }

  .spinner {
    animation: spin 1s linear infinite;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* === Form Status === */
  .form-status {
    text-align: center; padding: 8px; min-height: 20px;
    font-size: .9rem; font-weight: 500;
  }
  .form-status.error { color: #dc3545; }
  .form-status.success { color: #28a745; }

  /* === Info Cards === */
  .info-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px;
  }
  .info-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
    text-align: center;
    box-shadow: 0 4px 16px rgba(15,42,68,.06);
    transition: transform .2s, box-shadow .2s;
  }
  .info-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow);
  }
  .info-icon { font-size: 1.8rem; margin-bottom: 10px; }
  .info-card h3 { font-size: .95rem; margin-bottom: 6px; }
  .info-card p { font-size: .85rem; color: var(--muted); }

  /* === Footer === */
  .site-footer {
    border-top: 1px solid var(--border);
    background: rgba(240,248,255,.8);
    padding: 20px 0;
    margin-top: 16px;
  }
  .footer-inner {
    text-align: center; font-size: .85rem; color: var(--muted);
  }
  .footer-inner p { margin: 4px 0; }
  .footer-inner a { color: var(--brand2); }

  /* === Mobile CTA === */
  .mobile-cta {
    position: fixed; right: 16px; bottom: 16px; z-index: 30;
  }
  .mobile-cta-btn {
    display: inline-flex; align-items: center; justify-content: center;
    width: 56px; height: 56px; border-radius: 999px;
    background: linear-gradient(135deg, var(--brand), var(--brand2));
    color: #fff; border: none;
    box-shadow: 0 10px 24px rgba(6,182,212,.3);
    text-decoration: none;
    animation: cta-ring 700ms ease-out 500ms 1;
  }
  .mobile-cta-btn:hover { filter: brightness(1.05); text-decoration: none; }

  @keyframes cta-ring {
    0% { transform: scale(1) rotate(0); }
    20% { transform: scale(1.06) rotate(-8deg); }
    40% { transform: scale(1.06) rotate(8deg); }
    60% { transform: scale(1.04) rotate(-6deg); }
    80% { transform: scale(1.02) rotate(4deg); }
    100% { transform: scale(1) rotate(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* === Responsive === */
  @media (max-width: 600px) {
    .booking-grid { grid-template-columns: 1fr; }
    .return-fields { grid-template-columns: 1fr; }
    .info-grid { grid-template-columns: 1fr; }
    .trip-type-options { flex-direction: column; gap: 8px; }
    .trip-pill { width: 100%; justify-content: center; }
    .nav a { padding: 8px 10px; font-size: .85rem; }
  }

  @media (min-width: 900px) {
    .mobile-cta { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-cta-btn { animation: none; }
    .return-section { animation: none; }
  }
</style>

<script is:inline>
  const API_BASE = "";  // same origin — booking.datmo.io.vn

  const form = document.getElementById('booking-form');
  const tripTypeInputs = document.querySelectorAll('input[name="trip_type"]');
  const routeSelect = document.getElementById('route');
  const adultsInput = document.getElementById('adults');
  const childrenInput = document.getElementById('children');
  const totalAmountEl = document.getElementById('total-amount');
  const priceBreakdownEl = document.getElementById('price-breakdown');
  const statusEl = document.getElementById('booking-status');
  const returnSection = document.getElementById('return-section');
  const returnDateInput = document.getElementById('return_date');
  const submitBtn = document.getElementById('submit-btn');
  const btnText = document.getElementById('btn-text');
  const btnSpinner = document.getElementById('btn-spinner');

  // Trip type toggle
  tripTypeInputs.forEach(input => {
    input.addEventListener('change', (e) => {
      const isRoundTrip = e.target.value === 'round-trip';
      returnSection.style.display = isRoundTrip ? 'block' : 'none';
      if (returnDateInput) returnDateInput.required = isRoundTrip;
      calculateTotal();
    });
  });

  // Get return route price
  function getRoutePrice(routeValue) {
    const options = routeSelect.options;
    for (let i = 0; i < options.length; i++) {
      if (options[i].value === routeValue) {
        return {
          adult: parseInt(options[i].dataset.adultPrice) || 0,
          child: parseInt(options[i].dataset.childPrice) || 0
        };
      }
    }
    return { adult: 0, child: 0 };
  }

  // Calculate total
  function calculateTotal() {
    const selectedOption = routeSelect.selectedOptions[0];
    const adultPrice = parseInt(selectedOption?.dataset.adultPrice) || 0;
    const childPrice = parseInt(selectedOption?.dataset.childPrice) || 0;
    const adults = parseInt(adultsInput.value) || 1;
    const children = parseInt(childrenInput.value) || 0;

    const outboundTotal = (adults * adultPrice) + (children * childPrice);

    const isRoundTrip = document.querySelector('input[name="trip_type"]:checked')?.value === 'round-trip';
    let returnTotal = 0;

    if (isRoundTrip) {
      const returnRoute = selectedOption?.dataset?.reverse || '';
      const returnPrices = getRoutePrice(returnRoute);
      returnTotal = (adults * returnPrices.adult) + (children * returnPrices.child);
    }

    const total = outboundTotal + returnTotal;
    totalAmountEl.textContent = total.toLocaleString('vi-VN') + ' đ';

    if (isRoundTrip && total > 0) {
      priceBreakdownEl.style.display = 'block';
      priceBreakdownEl.textContent = `Chiều đi: ${outboundTotal.toLocaleString('vi-VN')}đ + Chiều về: ${returnTotal.toLocaleString('vi-VN')}đ`;
    } else {
      priceBreakdownEl.style.display = 'none';
    }
  }

  routeSelect.addEventListener('change', calculateTotal);
  adultsInput.addEventListener('input', calculateTotal);
  childrenInput.addEventListener('input', calculateTotal);

  // Form submit
  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    statusEl.textContent = '';
    statusEl.className = 'form-status full-width';
    submitBtn.disabled = true;
    btnText.textContent = 'Đang xử lý...';
    btnSpinner.classList.remove('hidden');

    const formData = new FormData(form);
    const isRoundTrip = formData.get('trip_type') === 'round-trip';

    const data = {
      trip_type: isRoundTrip ? 'round-trip' : 'one-way',
      route: formData.get('route'),
      travel_date: formData.get('travel_date'),
      departure_time: formData.get('departure_time') || null,
      adults: parseInt(formData.get('adults')) || 1,
      children: parseInt(formData.get('children')) || 0,
      passenger_name: formData.get('passenger_name'),
      passenger_phone: formData.get('passenger_phone'),
      passenger_email: formData.get('passenger_email') || null
    };

    if (isRoundTrip) {
      data.return_date = formData.get('return_date');
      data.return_departure_time = formData.get('return_departure_time') || null;
    }

    try {
      const res = await fetch(API_BASE + '/api/booking/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });

      const result = await res.json();

      if (result.success) {
        const bookingId = result.booking_id || result.booking_ids?.[0];
        window.location.href = '/xac-nhan/?id=' + bookingId;
      } else {
        statusEl.textContent = result.error || 'Có lỗi xảy ra. Vui lòng thử lại.';
        statusEl.className = 'form-status full-width error';
        submitBtn.disabled = false;
        btnText.textContent = 'Tiếp tục thanh toán';
        btnSpinner.classList.add('hidden');
      }
    } catch (err) {
      statusEl.textContent = 'Lỗi kết nối. Vui lòng thử lại.';
      statusEl.className = 'form-status full-width error';
      submitBtn.disabled = false;
      btnText.textContent = 'Tiếp tục thanh toán';
      btnSpinner.classList.add('hidden');
    }
  });
</script>
