---
const title = "Xác nhận đặt vé | Đất Mỏ Travel";
const description = "Xem thông tin đặt vé và thanh toán chuyển khoản.";
---

<!doctype html>
<html lang="vi">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="noindex,nofollow" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- Header -->
  <header class="site-header">
    <div class="container header-inner">
      <a class="brand" href="/" aria-label="Đặt vé tàu cao tốc">
        <div class="brand-badge"></div>
        <span>Đất Mỏ Travel</span>
      </a>
      <nav class="nav">
        <a href="/">← Đặt vé mới</a>
      </nav>
    </div>
  </header>

  <main id="main">
    <section class="container section">
      <div class="confirm-wrapper" id="booking-app">

        <!-- Loading -->
        <div class="state-box" id="loading">
          <div class="loader"></div>
          <p>Đang tải thông tin đặt vé...</p>
        </div>

        <!-- Booking Details -->
        <div class="hidden" id="booking-details">

          <!-- Trip Type Badge -->
          <div class="trip-badge" id="trip-type-badge" style="display:none;">
            <span class="badge-pill">🔄 Khứ hồi</span>
          </div>

          <!-- Booking Info Card -->
          <div class="card">
            <h2>📋 Thông tin đặt vé</h2>

            <div class="info-grid">
              <div class="info-row highlight-row">
                <span class="info-label">Mã đặt vé</span>
                <span class="info-value booking-id-text" id="booking-id">—</span>
              </div>

              <!-- Outbound -->
              <div class="trip-section">
                <div class="trip-header">✈️ Chiều đi</div>
                <div class="info-row">
                  <span class="info-label">Tuyến</span>
                  <span class="info-value" id="route-label">—</span>
                </div>
                <div class="info-row">
                  <span class="info-label">Ngày đi</span>
                  <span class="info-value" id="travel-date">—</span>
                </div>
                <div class="info-row">
                  <span class="info-label">Giờ khởi hành</span>
                  <span class="info-value" id="departure-time">—</span>
                </div>
              </div>

              <!-- Return (hidden by default) -->
              <div class="trip-section return-bg hidden" id="return-trip-section">
                <div class="trip-header">↩ Chiều về</div>
                <div class="info-row">
                  <span class="info-label">Tuyến</span>
                  <span class="info-value" id="return-route-label">—</span>
                </div>
                <div class="info-row">
                  <span class="info-label">Ngày về</span>
                  <span class="info-value" id="return-travel-date">—</span>
                </div>
                <div class="info-row">
                  <span class="info-label">Giờ khởi hành</span>
                  <span class="info-value" id="return-departure-time">—</span>
                </div>
              </div>

              <div class="info-row">
                <span class="info-label">Số khách</span>
                <span class="info-value" id="passenger-count">—</span>
              </div>
              <div class="info-row">
                <span class="info-label">Hành khách</span>
                <span class="info-value" id="passenger-name">—</span>
              </div>
              <div class="info-row">
                <span class="info-label">Điện thoại</span>
                <span class="info-value" id="passenger-phone">—</span>
              </div>
              <div class="info-row total-row">
                <span class="info-label">Tổng tiền</span>
                <span class="info-value total-amount" id="total-amount">—</span>
              </div>
            </div>
          </div>

          <!-- Payment Card -->
          <div class="card payment-card" id="payment-section">
            <h2>💳 Thanh toán</h2>
            <p class="small">Quý khách vui lòng chuyển khoản trong vòng <strong class="countdown" id="countdown">15:00</strong></p>

            <div class="bank-info">
              <div class="bank-row"><span>Ngân hàng</span><strong>Vietcombank</strong></div>
              <div class="bank-row"><span>Số tài khoản</span><strong>9988923239</strong></div>
              <div class="bank-row"><span>Tên tài khoản</span><strong>PHAM TOAN TRUNG</strong></div>
              <div class="bank-row transfer-row">
                <span>Nội dung CK</span>
                <strong id="transfer-note">—</strong>
              </div>
            </div>

            <div class="qr-section">
              <p class="small">Quét QR để thanh toán:</p>
              <img id="qr-image" src="" alt="QR thanh toán" class="qr-image" />
            </div>
          </div>

          <!-- Status -->
          <div class="card status-card" id="status-section">
            <div id="status-badge"><span class="badge status-pending">Chờ thanh toán</span></div>
            <p class="small" id="status-text">Đơn đặt vé đang chờ thanh toán. Vui lòng chuyển khoản để xác nhận.</p>
          </div>

          <!-- Success -->
          <div class="card success-card hidden" id="success-section">
            <h2>✅ Vé đã được xác nhận!</h2>
            <p>Vé của quý khách đã được xác nhận thành công.</p>
            <div class="ticket-info" id="outbound-ticket">
              <p><strong>✈️ Vé chiều đi:</strong> <span id="kalong-ref">—</span></p>
            </div>
            <div class="ticket-info hidden" id="return-ticket">
              <p><strong>↩ Vé chiều về:</strong> <span id="return-kalong-ref">—</span></p>
            </div>
            <p class="small">Cảm ơn quý khách đã sử dụng dịch vụ của Đất Mỏ Travel!</p>
          </div>

          <!-- Expired -->
          <div class="card expired-card hidden" id="expired-section">
            <h2>⚠️ Đơn hết hiệu lực</h2>
            <p>Đơn đặt vé đã hết hiệu lực do quá thời gian thanh toán.</p>
            <a href="/" class="btn primary">Đặt lại vé</a>
          </div>
        </div>

        <!-- Error -->
        <div class="state-box hidden" id="error">
          <div class="error-icon">😕</div>
          <p>Không tìm thấy thông tin đặt vé.</p>
          <a href="/" class="btn primary">Đặt vé mới</a>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <p>© {new Date().getFullYear()} <a href="https://datmo.io.vn">Datmo.io.vn</a> — Công ty CP Thương mại và Du lịch Đất Mỏ</p>
      <p>Hotline: <a href="tel:+84911321578">0911 321 578</a></p>
    </div>
  </footer>
</body>
</html>

<style>
  :root {
    --bg: #f5fbff;
    --card: #ffffff;
    --text: #0f2a44;
    --muted: #4b6b8a;
    --brand: #06b6d4;
    --brand2: #3b82f6;
    --border: rgba(15,42,68,.12);
    --shadow: 0 12px 30px rgba(15,42,68,.10);
    --radius: 18px;
    --container: 620px;
    --container-pad: 16px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;
    background:
      radial-gradient(900px 500px at 0% 0%, rgba(6,182,212,.2), transparent 60%),
      radial-gradient(700px 500px at 100% 0%, rgba(59,130,246,.18), transparent 55%),
      linear-gradient(180deg, #f5fbff 0%, #eef6ff 100%);
    color: var(--text);
    line-height: 1.65;
    min-height: 100vh;
  }
  a { color: var(--brand2); text-decoration: none; }
  a:hover { text-decoration: underline; }

  .container { max-width: var(--container); margin: 0 auto; padding: 0 var(--container-pad); }
  .section { padding: 24px 0 32px; }
  .hidden { display: none !important; }
  .small { color: var(--muted); font-size: .875rem; }

  /* Header */
  .site-header {
    position: sticky; top: 0; z-index: 20;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background: rgba(255,255,255,.8);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    display: flex; align-items: center; justify-content: space-between;
    gap: 12px; padding: 12px 0;
  }
  .brand { display: flex; align-items: center; gap: 10px; font-weight: 800; color: var(--text); text-decoration: none; }
  .brand:hover { text-decoration: none; }
  .brand-badge {
    width: 34px; height: 34px; border-radius: 10px;
    background: linear-gradient(135deg, var(--brand), var(--brand2));
    box-shadow: var(--shadow);
  }
  .nav a {
    padding: 8px 14px; border-radius: 10px;
    font-size: .9rem; font-weight: 500;
    color: var(--muted); transition: background .2s;
  }
  .nav a:hover { background: rgba(6,182,212,.08); text-decoration: none; }

  /* State boxes */
  .state-box { text-align: center; padding: 60px 20px; }
  .error-icon { font-size: 3rem; margin-bottom: 16px; }
  .loader {
    width: 36px; height: 36px; margin: 0 auto 16px;
    border: 3px solid rgba(6,182,212,.2);
    border-top-color: var(--brand);
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Cards */
  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 24px;
    margin-bottom: 16px;
  }
  .card h2 { font-size: 1.2rem; margin-bottom: 16px; }

  /* Trip Badge */
  .trip-badge { text-align: center; margin-bottom: 12px; }
  .badge-pill {
    display: inline-block;
    background: linear-gradient(135deg, rgba(6,182,212,.1), rgba(59,130,246,.1));
    color: var(--brand2);
    padding: 8px 20px; border-radius: 20px;
    font-weight: 600; font-size: .9rem;
  }

  /* Info Grid */
  .info-grid { display: flex; flex-direction: column; gap: 2px; }
  .info-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 10px 0;
  }
  .highlight-row { padding: 12px 16px; background: rgba(6,182,212,.04); border-radius: 12px; margin-bottom: 8px; }
  .info-label { color: var(--muted); font-size: .9rem; }
  .info-value { font-weight: 600; text-align: right; }
  .booking-id-text { font-family: 'Courier New', monospace; font-size: 1.1rem; color: var(--brand2); letter-spacing: .5px; }

  .trip-section { border-bottom: 1px dashed rgba(15,42,68,.1); padding-bottom: 8px; margin-bottom: 8px; }
  .trip-header { font-weight: 700; color: var(--brand); margin-bottom: 4px; font-size: .95rem; }
  .return-bg { background: rgba(240,248,255,.8); margin: 8px -24px; padding: 12px 24px; }

  .total-row {
    border-top: 2px solid var(--brand);
    padding-top: 14px; margin-top: 10px;
  }
  .total-amount { font-size: 1.3rem; color: var(--brand2); }

  /* Payment */
  .payment-card { background: linear-gradient(180deg, #fafeff, #f0f8ff); }
  .countdown { font-size: 1.6rem; color: #dc3545; font-weight: 800; }
  .bank-info { background: #fff; border-radius: 14px; padding: 16px; margin: 16px 0; border: 1px solid var(--border); }
  .bank-row { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid rgba(15,42,68,.06); }
  .bank-row:last-child { border-bottom: none; }
  .transfer-row {
    background: #fff8e1; margin: 8px -16px -16px; padding: 14px 16px;
    border-radius: 0 0 14px 14px; border-top: 2px dashed #ffc107;
  }
  .qr-section { text-align: center; margin-top: 16px; }
  .qr-image { max-width: 220px; border-radius: 12px; border: 2px solid var(--border); box-shadow: 0 4px 16px rgba(0,0,0,.06); }

  /* Status */
  .status-card { text-align: center; }
  .badge {
    display: inline-block; padding: 8px 20px;
    border-radius: 20px; font-weight: 600; font-size: .9rem;
    margin-bottom: 8px;
  }
  .status-pending { background: #fff3cd; color: #856404; }
  .status-paid { background: #cce5ff; color: #004085; }
  .status-issued { background: #d4edda; color: #155724; }
  .status-expired { background: #f8d7da; color: #721c24; }

  /* Success */
  .success-card { text-align: center; background: linear-gradient(180deg, #e8f8ee, #d4edda); border-color: #c3e6cb; }
  .success-card h2 { color: #155724; }
  .ticket-info { background: #fff; padding: 14px 18px; border-radius: 12px; margin: 10px 0; text-align: left; }

  /* Expired */
  .expired-card { text-align: center; background: linear-gradient(180deg, #fef0f0, #f8d7da); border-color: #f5c6cb; }
  .expired-card h2 { color: #721c24; }

  /* Button */
  .btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    padding: 12px 24px; border-radius: 14px; border: none;
    font: inherit; font-weight: 700; cursor: pointer;
    transition: all .2s; text-decoration: none;
  }
  .btn.primary {
    background: linear-gradient(135deg, var(--brand), var(--brand2));
    color: #fff;
    box-shadow: 0 8px 24px rgba(6,182,212,.3);
  }
  .btn.primary:hover { filter: brightness(1.06); text-decoration: none; transform: translateY(-1px); }

  /* Footer */
  .site-footer {
    border-top: 1px solid var(--border);
    background: rgba(240,248,255,.8);
    padding: 20px 0; margin-top: 16px;
  }
  .footer-inner { text-align: center; font-size: .85rem; color: var(--muted); }
  .footer-inner p { margin: 4px 0; }
</style>

<script is:inline>
  const API_BASE = "";  // same origin
  const bookingId = new URLSearchParams(window.location.search).get('id');

  const loadingEl = document.getElementById('loading');
  const bookingDetailsEl = document.getElementById('booking-details');
  const errorEl = document.getElementById('error');
  const successSection = document.getElementById('success-section');
  const expiredSection = document.getElementById('expired-section');
  const paymentSection = document.getElementById('payment-section');
  const tripTypeBadge = document.getElementById('trip-type-badge');
  const returnSection = document.getElementById('return-trip-section');
  const returnTicket = document.getElementById('return-ticket');

  let bookingData = null;
  let countdownInterval = null;

  async function fetchBooking() {
    if (!bookingId) { showError(); return; }

    try {
      const res = await fetch(API_BASE + '/api/booking/status?id=' + bookingId);
      const data = await res.json();

      if (data.success && data.booking) {
        bookingData = data.booking;
        displayBooking(bookingData);
      } else {
        showError();
      }
    } catch (err) {
      console.error('Error fetching booking:', err);
      showError();
    }
  }

  function formatDate(dateStr) {
    const date = new Date(dateStr);
    return date.toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' });
  }

  function displayBooking(booking) {
    loadingEl.classList.add('hidden');
    bookingDetailsEl.classList.remove('hidden');

    const isRoundTrip = booking.trip_type === 'round-trip';

    if (tripTypeBadge) {
      tripTypeBadge.style.display = isRoundTrip ? 'block' : 'none';
    }

    document.getElementById('booking-id').textContent = booking.id;
    document.getElementById('route-label').textContent = booking.route_label || booking.route;
    document.getElementById('travel-date').textContent = formatDate(booking.travel_date);
    document.getElementById('departure-time').textContent = booking.departure_time || 'Theo lịch tàu';
    document.getElementById('passenger-count').textContent =
      booking.adults + ' người lớn' + (booking.children > 0 ? ', ' + booking.children + ' trẻ em' : '');
    document.getElementById('passenger-name').textContent = booking.passenger_name;
    document.getElementById('passenger-phone').textContent = booking.passenger_phone;
    document.getElementById('total-amount').textContent = booking.total_amount.toLocaleString('vi-VN') + ' đ';
    document.getElementById('transfer-note').textContent = booking.id;

    // Return trip
    if (isRoundTrip && booking.linked_booking) {
      returnSection.classList.remove('hidden');
      document.getElementById('return-route-label').textContent = booking.linked_booking.route_label || booking.linked_booking.route;
      document.getElementById('return-travel-date').textContent = formatDate(booking.linked_booking.travel_date);
      document.getElementById('return-departure-time').textContent = booking.linked_booking.departure_time || 'Theo lịch tàu';
    }

    // QR image
    const qrImg = document.getElementById('qr-image');
    if (booking.status === 'pending_payment') {
      const encodedNote = encodeURIComponent(booking.id);
      qrImg.src = `https://img.vietqr.io/image/9988923239-compact2.png?amount=${booking.total_amount}&addInfo=${encodedNote}&accountName=${encodeURIComponent('PHAM TOAN TRUNG')}`;
      startCountdown(booking.expires_at);
    }

    // Status display
    const statusBadge = document.getElementById('status-badge');
    const statusText = document.getElementById('status-text');

    if (booking.status === 'pending_payment') {
      statusBadge.innerHTML = '<span class="badge status-pending">Chờ thanh toán</span>';
      statusText.textContent = 'Đơn đặt vé đang chờ thanh toán. Vui lòng chuyển khoản để xác nhận.';
    } else if (booking.status === 'paid') {
      statusBadge.innerHTML = '<span class="badge status-paid">Đã thanh toán</span>';
      statusText.textContent = 'Đơn đặt vé đã được thanh toán. Đang chờ xuất vé...';
      paymentSection.classList.add('hidden');
    } else if (booking.status === 'issued') {
      paymentSection.classList.add('hidden');
      successSection.classList.remove('hidden');
      document.getElementById('kalong-ref').textContent = booking.kalong_booking_ref || booking.id;

      if (isRoundTrip && booking.linked_booking) {
        returnTicket.classList.remove('hidden');
        document.getElementById('return-kalong-ref').textContent = booking.linked_booking.kalong_booking_ref || booking.linked_booking.id;
      }

      statusBadge.innerHTML = '<span class="badge status-issued">Đã xuất vé</span>';
      statusText.textContent = 'Vé của quý khách đã được xác nhận!';
    } else if (booking.status === 'expired') {
      paymentSection.classList.add('hidden');
      expiredSection.classList.remove('hidden');
      statusBadge.innerHTML = '<span class="badge status-expired">Hết hạn</span>';
    }
  }

  function startCountdown(expiresAt) {
    const countdownEl = document.getElementById('countdown');

    function update() {
      const now = new Date();
      const expires = new Date(expiresAt);
      const diff = expires - now;

      if (diff <= 0) {
        countdownEl.textContent = '00:00';
        clearInterval(countdownInterval);
        fetchBooking();
        return;
      }

      const minutes = Math.floor(diff / 60000);
      const seconds = Math.floor((diff % 60000) / 1000);
      countdownEl.textContent =
        String(minutes).padStart(2, '0') + ':' +
        String(seconds).padStart(2, '0');
    }

    update();
    countdownInterval = setInterval(update, 1000);
  }

  function showError() {
    loadingEl.classList.add('hidden');
    errorEl.classList.remove('hidden');
  }

  // Auto-refresh every 30 seconds
  setInterval(fetchBooking, 30000);
  fetchBooking();
</script>
