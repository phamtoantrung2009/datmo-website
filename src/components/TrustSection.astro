---
/**
 * TrustSection – Hiển thị số liệu nổi bật + trust badges
 * Đặt ngay sau Hero trên trang chủ
 */
---
<section class="trust-section reveal" aria-label="Thông tin uy tín">
  <div class="container">
    <div class="trust-grid">
      <div class="trust-item">
        <div class="trust-number">5+</div>
        <div class="trust-label">Năm kinh nghiệm</div>
      </div>
      <div class="trust-item">
        <div class="trust-number">1000+</div>
        <div class="trust-label">Khách hàng phục vụ</div>
      </div>
      <div class="trust-item">
        <div class="trust-number">6+</div>
        <div class="trust-label">Dịch vụ trọn gói</div>
      </div>
      <div class="trust-item">
        <div class="trust-number">24/7</div>
        <div class="trust-label">Hỗ trợ nhanh</div>
      </div>
    </div>

    <div class="trust-badge-row">
      <span class="trust-badge">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L3 7v5c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5zm-1 14.59l-3.3-3.3 1.41-1.41L11 13.77l4.89-4.89 1.41 1.41L11 16.59z"/></svg>
        Công ty CP có GPKD
      </span>
      <span class="trust-badge">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z"/></svg>
        MST: 5702169493
      </span>
      <span class="trust-badge">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
        Quảng Ninh
      </span>
    </div>
  </div>
</section>
