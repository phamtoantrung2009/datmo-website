---
const services = [
  { img: '/images/thue-xe-du-lich.png', icon: '<path d="M18.9 6c-.2-.6-.8-1-1.4-1H6.5c-.7 0-1.2.4-1.4 1L3 12v8c0 .6.4 1 1 1h1c.6 0 1-.4 1-1v-1h12v1c0 .6.4 1 1 1h1c.6 0 1-.4 1-1v-8l-2.1-6zM6.5 16c-.8 0-1.5-.7-1.5-1.5S5.7 13 6.5 13s1.5.7 1.5 1.5S7.3 16 6.5 16zm11 0c-.8 0-1.5-.7-1.5-1.5s.7-1.5 1.5-1.5 1.5.7 1.5 1.5-.7 1.5-1.5 1.5zM5 11l1.5-4.5h11L19 11H5z"/>', title: 'Thuê xe du lịch', desc: '16 – 45 chỗ tại Cẩm Phả', href: '/thue-xe-du-lich/' },
  { img: '/images/tour-du-lich.png', icon: '<path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>', title: 'Tour du lịch', desc: 'Nội địa • Quốc tế • Tour đoàn', href: '/tour-du-lich/' },
  { img: '/images/tau-cao-toc.png', icon: '<path d="M20 21c-1.39 0-2.78-.47-4-1.32-2.44 1.71-5.56 1.71-8 0C6.78 20.53 5.39 21 4 21H2v2h2c1.38 0 2.74-.35 4-.99 2.52 1.29 5.48 1.29 8 0 1.26.65 2.62.99 4 .99h2v-2h-2zM3.95 19H4c1.6 0 3.02-.88 4-2 .98 1.12 2.4 2 4 2s3.02-.88 4-2c.98 1.12 2.4 2 4 2h.05l1.89-6.68c.08-.26.06-.54-.06-.78s-.34-.42-.6-.5L20 10.62V6c0-1.1-.9-2-2-2h-3V1H9v3H6c-1.1 0-2 .9-2 2v4.62l-1.29.42c-.26.08-.48.26-.6.5s-.15.52-.06.78L3.95 19zM6 6h12v3.97L12 8 6 9.97V6z"/>', title: 'Vé tàu cao tốc', desc: 'Ao Tiên/Vũng Đục ↔ Cô Tô/Quan Lạn', href: '/ve-tau-cao-toc/' },
  { img: '/images/ve-may-bay.png', icon: '<path d="M21 16v-2l-8-5V3.5c0-.83-.67-1.5-1.5-1.5S10 2.67 10 3.5V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-5.5l8 2.5z"/>', title: 'Vé máy bay', desc: 'Báo giá nhanh, hỗ trợ đổi vé', href: '/ve-may-bay/' },
  { img: '/images/khach-san.png', icon: '<path d="M7 13c1.66 0 3-1.34 3-3S8.66 7 7 7s-3 1.34-3 3 1.34 3 3 3zm12-6h-8v7H3V5H1v15h2v-3h18v3h2v-9c0-2.21-1.79-4-4-4z"/>', title: 'Khách sạn', desc: 'Cẩm Phả, Hạ Long, Vân Đồn', href: '/khach-san/' },
  { img: '/images/visa-ho-chieu.png', icon: '<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2v-4h2v4zm0-6h-2V8h2v2z"/>', title: 'Visa – hộ chiếu', desc: 'Tư vấn hồ sơ, thời gian xử lý nhanh chóng', href: '/visa-ho-chieu/' },
];
---
<div class="grid-3 reveal">
  {services.map((s) => (
    <a class="svc-card" href={s.href}>
      {s.img ? (
        <div class="svc-card-img">
          <img src={s.img} alt={s.title} loading="lazy" width="400" height="225" />
        </div>
      ) : (
        <div class="svc-card-img" style="background:#eef3f9;display:flex;align-items:center;justify-content:center">
          <svg viewBox="0 0 24 24" fill="var(--brand)" width="48" height="48" set:html={s.icon}></svg>
        </div>
      )}
      <div class="svc-card-body">
        <h3>
          <span class="svc-icon">
            <svg viewBox="0 0 24 24" fill="currentColor" set:html={s.icon}></svg>
          </span>
          {s.title}
        </h3>
        <p>{s.desc}</p>
      </div>
    </a>
  ))}
</div>
