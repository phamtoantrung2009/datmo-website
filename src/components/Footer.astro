---
import { SITE } from '../config/site';
---
<footer class="site-footer">
  <div class="container footer-grid reveal">
    <div class="footer-col footer-info">
      <a class="brand" href="/" aria-label="Trang chủ Datmo.io.vn" style="margin-bottom:16px;display:inline-flex">
        <img src="/logo.png" alt={SITE.name} class="brand-logo" width="360" height="104" loading="lazy" />
      </a>
      <p class="small" style="margin-top:0">
        Dịch vụ du lịch & vận chuyển hàng đầu tại Cẩm Phả – Quảng Ninh. Uy tín, trọn gói, hỗ trợ 24/7.
      </p>
      <div class="footer-contact">
        <div class="footer-contact-item">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
        </div>
        <div class="footer-contact-item">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
          <a href={`tel:${SITE.phone}`}>{SITE.phoneDisplay}</a>
        </div>
        <div class="footer-contact-item">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
          <span>{SITE.address.streetAddress}</span>
        </div>
      </div>
    </div>

    <div class="footer-col">
      <h3>Dịch vụ chính</h3>
      <ul>
        <li><a href="/thue-xe-du-lich/">Thuê xe du lịch 16–45 chỗ</a></li>
        <li><a href="/tour-du-lich/">Tour du lịch trong & ngoài nước</a></li>
        <li><a href="/ve-tau-cao-toc/">Vé tàu cao tốc Cô Tô/Quan Lạn</a></li>
        <li><a href="/ve-may-bay/">Đặt vé máy bay</a></li>
        <li><a href="/khach-san/">Đặt phòng khách sạn</a></li>
        <li><a href="/visa-ho-chieu/">Dịch vụ visa – hộ chiếu</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h3>Thông tin pháp lý</h3>
      <address class="footer-legal">
        <p><strong>CÔNG TY CP THƯƠNG MẠI VÀ DU LỊCH ĐẤT MỎ</strong></p>
        <p>MST: 5702169493</p>
        <p>Trụ sở: Số nhà 22, tổ 33, khu 4A2, Phường Cửa Ông, TP Cẩm Phả, Quảng Ninh</p>
        <hr style="border:0; border-top:1px dashed var(--border); margin:8px 0" />
        <p>Văn phòng: Số nhà 56, tổ 51, khu 4B2, Phường Cửa Ông, TP Cẩm Phả, Quảng Ninh</p>
      </address>
    </div>
  </div>

  <div class="container footer-bottom">
    <p class="small" style="margin:0">© {new Date().getFullYear()} Datmo.io.vn. Bản quyền thuộc về CTY CP TM & DL Đất Mỏ.</p>
    <div class="footer-social">
      <a href={SITE.zaloUrl} rel="nofollow" aria-label="Zalo">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M21 16.5v3.25a1.25 1.25 0 0 1-1.37 1.24A18.8 18.8 0 0 1 3 4.37 1.25 1.25 0 0 1 4.24 3H7.5A1.25 1.25 0 0 1 8.75 4.1c.1.9.3 1.78.6 2.63a1.25 1.25 0 0 1-.28 1.31L7.9 9.2a15.5 15.5 0 0 0 6.9 6.9l1.16-1.17a1.25 1.25 0 0 1 1.31-.28c.85.3 1.73.5 2.63.6A1.25 1.25 0 0 1 21 16.5z"/></svg>
      </a>
      {SITE.social && SITE.social.facebook && (
        <a href={SITE.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"/></svg>
        </a>
      )}
    </div>
  </div>
</footer>
