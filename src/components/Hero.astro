---
import { SITE } from '../config/site';
type Props = { h1: string; sub: string };
const { h1, sub } = Astro.props;
---
<section class="hero">
  <div class="hero-bg">
    <img src="/images/hero-quang-ninh.png" alt="Vịnh Hạ Long, Quảng Ninh" width="1920" height="1080" loading="eager" fetchpriority="high" />
  </div>
  <div class="hero-overlay"></div>

  <div class="container hero-content">
    <div class="kicker">Cẩm Phả • Quảng Ninh</div>
    <h1>{h1}</h1>
    <p class="lead">{sub}</p>

    <div class="btn-row">
      <a class="btn hero-btn primary" href={`tel:${SITE.phone}`}>
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M21 16.5v3.25a1.25 1.25 0 0 1-1.37 1.24A18.8 18.8 0 0 1 3 4.37 1.25 1.25 0 0 1 4.24 3H7.5A1.25 1.25 0 0 1 8.75 4.1c.1.9.3 1.78.6 2.63a1.25 1.25 0 0 1-.28 1.31L7.9 9.2a15.5 15.5 0 0 0 6.9 6.9l1.16-1.17a1.25 1.25 0 0 1 1.31-.28c.85.3 1.73.5 2.63.6A1.25 1.25 0 0 1 21 16.5z"/></svg>
        Gọi ngay
      </a>
      <a class="btn hero-btn" href={SITE.zaloUrl} rel="nofollow">Nhắn Zalo</a>
      <a class="btn hero-btn" href="/lien-he/">Đặt dịch vụ</a>
    </div>

    <div class="hero-trust">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L3 7v5c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5zm-1 14.59l-3.3-3.3 1.41-1.41L11 13.77l4.89-4.89 1.41 1.41L11 16.59z"/></svg>
      Công ty CP có giấy phép kinh doanh • MST: 5702169493
    </div>

    <div class="hero-services">
      <a class="hero-svc" href="/thue-xe-du-lich/">
        <span class="hero-svc-icon">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.9 6c-.2-.6-.8-1-1.4-1H6.5c-.7 0-1.2.4-1.4 1L3 12v8c0 .6.4 1 1 1h1c.6 0 1-.4 1-1v-1h12v1c0 .6.4 1 1 1h1c.6 0 1-.4 1-1v-8l-2.1-6zM6.5 16c-.8 0-1.5-.7-1.5-1.5S5.7 13 6.5 13s1.5.7 1.5 1.5S7.3 16 6.5 16zm11 0c-.8 0-1.5-.7-1.5-1.5s.7-1.5 1.5-1.5 1.5.7 1.5 1.5-.7 1.5-1.5 1.5zM5 11l1.5-4.5h11L19 11H5z"/></svg>
        </span>
        Thuê xe
      </a>
      <a class="hero-svc" href="/tour-du-lich/">
        <span class="hero-svc-icon">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
        </span>
        Tour
      </a>
      <a class="hero-svc" href="/ve-tau-cao-toc/">
        <span class="hero-svc-icon">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20 21c-1.39 0-2.78-.47-4-1.32-2.44 1.71-5.56 1.71-8 0C6.78 20.53 5.39 21 4 21H2v2h2c1.38 0 2.74-.35 4-.99 2.52 1.29 5.48 1.29 8 0 1.26.65 2.62.99 4 .99h2v-2h-2zM3.95 19H4c1.6 0 3.02-.88 4-2 .98 1.12 2.4 2 4 2s3.02-.88 4-2c.98 1.12 2.4 2 4 2h.05l1.89-6.68c.08-.26.06-.54-.06-.78s-.34-.42-.6-.5L20 10.62V6c0-1.1-.9-2-2-2h-3V1H9v3H6c-1.1 0-2 .9-2 2v4.62l-1.29.42c-.26.08-.48.26-.6.5s-.15.52-.06.78L3.95 19zM6 6h12v3.97L12 8 6 9.97V6z"/></svg>
        </span>
        Vé tàu
      </a>
      <a class="hero-svc" href="/ve-may-bay/">
        <span class="hero-svc-icon">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M21 16v-2l-8-5V3.5c0-.83-.67-1.5-1.5-1.5S10 2.67 10 3.5V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-5.5l8 2.5z"/></svg>
        </span>
        Máy bay
      </a>
    </div>
  </div>
</section>
