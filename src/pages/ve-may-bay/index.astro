---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getOgImage } from '../../config/og';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import JsonLd from '../../components/JsonLd.astro';
import CallToActions from '../../components/CallToActions.astro';
import { SITE } from '../../config/site';

// SEO: tune title/description length for SERP.
const title = 'Đ?t vé máy bay nhanh t?i C?m Ph?, Qu?ng Ninh | Datmo';
const description = 'Nh?n d?t vé máy bay cho khách C?m Ph? – Qu?ng Ninh: tu v?n hành tŕnh, báo giá nhanh, h? tr? d?i vé theo di?u ki?n hăng. H? tr? nhanh qua hotline.';
const ogImage = getOgImage('/ve-may-bay/');
const canonical = SITE.url + '/ve-may-bay/';

const crumbs = [
  { name: 'Trang ch?', href: '/' },
  { name: 'Đ?t vé máy bay t?i C?m Ph?', href: '/ve-may-bay/' },
];

const faqItems = [
  { q: 'C?n cung c?p thông tin ǵ d? d?t nhanh?', a: 'H? tên, ngày di (kh? h?i n?u có), tuy?n/di?m d?n và s? di?n tho?i liên h?.' },
  { q: 'Có h? tr? thay d?i/hoàn hu? không?', a: 'Tu? di?u ki?n c?a hăng/nhà cung c?p. Datmo h? tr? hu?ng d?n và x? lư theo quy d?nh.' },
];

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Đ?t vé máy bay t?i C?m Ph?',
  areaServed: ['C?m Ph?', 'Qu?ng Ninh'],
  provider: { '@type': 'LocalBusiness', name: SITE.name, url: SITE.url, telephone: SITE.phone },
  url: canonical,
};
---
<BaseLayout title={title} description={description} ogImage={ogImage} canonical={canonical} breadcrumb={crumbs}>
  <Breadcrumbs items={crumbs} />
  <section class="container section">
    <h1>Đ?t vé máy bay t?i C?m Ph?</h1>
    <p class="lead">Nh?n d?t vé máy bay cho khách t?i C?m Ph? – Qu?ng Ninh: tu v?n hành tŕnh, báo giá nhanh, h? tr? d?i vé theo di?u ki?n hăng.</p>

    <div class="card">
      <h2>Liên k?t cùng SILO</h2>
      <ul class="link-list">
        <li><a href="/khach-san/">Đ?t pḥng khách s?n</a></li><li><a href="/tour-du-lich/">Tour du l?ch</a></li><li><a href="/visa-ho-chieu/">Visa – h? chi?u</a></li>
      </ul>
    </div>
  </section>

  <FAQ items={faqItems} />
  <JsonLd data={serviceJsonLd} />
  <CallToActions />
</BaseLayout>
