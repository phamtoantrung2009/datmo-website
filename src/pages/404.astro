import Breadcrumbs from '../components/Breadcrumbs.astro';

// SEO: mark 404 as noindex to avoid indexing.
// SEO: tune title/description length for SERP.
const title = 'Không těm th?y trang (404) | Datmo C?m Ph?, Qu?ng Ninh';
const description = 'Trang b?n yęu c?u không t?n t?i ho?c dă du?c di chuy?n. Vui lňng quay l?i trang ch? ho?c ch?n d?ch v? du l?ch, thuę xe, vé tŕu, vé máy bay t?i Datmo.';
const crumbs = [
