---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getOgImage } from '../../../config/og';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FAQ from '../../../components/FAQ.astro';
import JsonLd from '../../../components/JsonLd.astro';
import CallToActions from '../../../components/CallToActions.astro';
import { SITE } from '../../../config/site';

// SEO: tune title/description length for SERP.
const title = 'Tour n?i d?a kh?i hŕnh C?m Ph?, Qu?ng Ninh | Datmo';
const description = 'G?i ý tour n?i d?a phů h?p ngân sách vŕ th?i gian: H? Long, Vân Đ?n, Móng Cái, Hŕ N?i. Tu v?n nhanh, linh ho?t l?ch trěnh vŕ xe dua dón, phů h?p nhóm gia děnh.';
const ogImage = getOgImage('/tour-du-lich/tour-noi-dia/');
const canonical = SITE.url + '/tour-du-lich/tour-noi-dia/';

const crumbs = [
  { name: 'Trang ch?', href: '/' },
  { name: 'Tour du l?ch', href: '/tour-du-lich/' },
  { name: 'Tour n?i d?a xu?t phát t? C?m Ph?', href: '/tour-du-lich/tour-noi-dia/' },
];

const faqItems = [
  { q: 'C?n cung c?p thông tin gě d? báo giá tour?', a: 'Ngŕy di, s? khách, di?m d?n mong mu?n, m?c ngân sách vŕ yęu c?u khách s?n/di chuy?n.' },
  { q: 'Có h? tr? dua dón t? C?m Ph? không?', a: 'Có. Có th? k?t h?p thuę xe 16–45 ch? theo doŕn.' },
];

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Tour n?i d?a xu?t phát t? C?m Ph?',
  areaServed: ['C?m Ph?', 'Qu?ng Ninh'],
  provider: { '@type': 'LocalBusiness', name: SITE.name, url: SITE.url, telephone: SITE.phone },
  url: canonical,
};
---
<BaseLayout title={title} description={description} ogImage={ogImage} canonical={canonical} breadcrumb={crumbs}>
  <Breadcrumbs items={crumbs} />
  <section class="container section">
    <h1>Tour n?i d?a xu?t phát t? C?m Ph?</h1>
    <p class="lead">Tu v?n tour trong nu?c cho khách C?m Ph?: l?ch trěnh linh ho?t, phů h?p gia děnh/công ty, có th? k?t h?p thuę xe vŕ d?t khách s?n.</p>

    <div class="card">
      <h2>G?i ý gói d?ch v?</h2>
      <ul>
        <li>L?ch trěnh linh ho?t theo ngŕy</li>
        <li>K?t h?p vé máy bay/khách s?n khi c?n</li>
        <li>H? tr? xe dua dón vŕ vé tŕu (n?u di d?o)</li>
      </ul>
      <p class="small">Xem thęm: <a href="/thue-xe-du-lich/">Thuę xe</a> • <a href="/ve-may-bay/">Vé máy bay</a> • <a href="/khach-san/">Khách s?n</a></p>
    </div>
  </section>

  <FAQ items={faqItems} />
  <JsonLd data={serviceJsonLd} />
  <CallToActions />
</BaseLayout>
