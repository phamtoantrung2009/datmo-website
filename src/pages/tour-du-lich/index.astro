---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getOgImage } from '../../config/og';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import JsonLd from '../../components/JsonLd.astro';
import { SITE } from '../../config/site';

// SEO: tune title/description length for SERP.
const title = 'Tour du l?ch tr?n gói t?i C?m Ph?, Qu?ng Ninh | Datmo';
const description = 'Tu v?n tour theo ngân sách và th?i gian: n?i d?a, qu?c t?, tour doàn. Xu?t phát t? C?m Ph?, t?i uu l?ch trình, h? tr? xe, khách s?n và vé. Giá minh b?ch.';
const ogImage = getOgImage('/tour-du-lich/');
const canonical = SITE.url + '/tour-du-lich/';

const crumbs = [
  { name: 'Trang ch?', href: '/' },
  { name: 'Tour du l?ch', href: '/tour-du-lich/' },
];

const faqItems = [
