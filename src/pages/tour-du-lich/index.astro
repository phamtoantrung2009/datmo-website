    <div class="grid-3">
      <a class="card" href="/tour-du-lich/tour-noi-dia/"><h3>Tour n?i d?a</h3><p>Trong nu?c, linh ho?t l?ch trình</p></a>
      <a class="card" href="/tour-du-lich/tour-quoc-te/"><h3>Tour qu?c t?</h3><p>Tu v?n l?ch trình & gi?y t?</p></a>
      <a class="card" href="/tour-du-lich/tour-doan/"><h3>Tour doàn</h3><p>Công ty, team building, s? ki?n</p></a>
    </div>

