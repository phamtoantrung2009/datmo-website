---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getOgImage } from '../../../config/og';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FAQ from '../../../components/FAQ.astro';
import JsonLd from '../../../components/JsonLd.astro';
import CallToActions from '../../../components/CallToActions.astro';
import { SITE } from '../../../config/site';

// SEO: tune title/description length for SERP.
const title = 'Tour qu?c t? tr?n gói t? C?m Ph?, Qu?ng Ninh | Datmo';
const description = 'Tu v?n tour qu?c t? theo nhu c?u: l?ch tŕnh, visa, khách s?n, vé máy bay và b?o hi?m. H? tr? h? so, kh?i hành t? C?m Ph?, tu v?n l?ch kh?i hành phù h?p.';
const ogImage = getOgImage('/tour-du-lich/tour-quoc-te/');
const canonical = SITE.url + '/tour-du-lich/tour-quoc-te/';

const crumbs = [
  { name: 'Trang ch?', href: '/' },
  { name: 'Tour du l?ch', href: '/tour-du-lich/' },
  { name: 'Tour qu?c t? xu?t phát t? C?m Ph?', href: '/tour-du-lich/tour-quoc-te/' },
];

const faqItems = [
  { q: 'C?n cung c?p thông tin ǵ d? báo giá tour?', a: 'Ngày di, s? khách, di?m d?n mong mu?n, m?c ngân sách và yêu c?u khách s?n/di chuy?n.' },
  { q: 'Có h? tr? dua dón t? C?m Ph? không?', a: 'Có. Có th? k?t h?p thuê xe 16–45 ch? theo doàn.' },
];

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Tour qu?c t? xu?t phát t? C?m Ph?',
  areaServed: ['C?m Ph?', 'Qu?ng Ninh'],
  provider: { '@type': 'LocalBusiness', name: SITE.name, url: SITE.url, telephone: SITE.phone },
  url: canonical,
};
---
<BaseLayout title={title} description={description} ogImage={ogImage} canonical={canonical} breadcrumb={crumbs}>
  <Breadcrumbs items={crumbs} />
  <section class="container section">
    <h1>Tour qu?c t? xu?t phát t? C?m Ph?</h1>
    <p class="lead">Tu v?n tour qu?c t? t? C?m Ph?: l?ch tŕnh, vé máy bay, khách s?n và h? tr? visa – h? chi?u tu? di?m d?n.</p>

    <div class="card">
      <h2>G?i ư gói d?ch v?</h2>
      <ul>
        <li>L?ch tŕnh linh ho?t theo ngày</li>
        <li>K?t h?p vé máy bay/khách s?n khi c?n</li>
        <li>H? tr? xe dua dón và vé tàu (n?u di d?o)</li>
      </ul>
      <p class="small">Xem thêm: <a href="/thue-xe-du-lich/">Thuê xe</a> • <a href="/ve-may-bay/">Vé máy bay</a> • <a href="/khach-san/">Khách s?n</a></p>
    </div>
  </section>

  <FAQ items={faqItems} />
  <JsonLd data={serviceJsonLd} />
  <CallToActions />
</BaseLayout>
