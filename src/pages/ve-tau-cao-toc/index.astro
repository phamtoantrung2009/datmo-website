---
import BaseLayout from '../../layouts/BaseLayout.astro';



import { getOgImage } from '../../config/og';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import JsonLd from '../../components/JsonLd.astro';
import { SITE } from '../../config/site';

// SEO: tune title/description length for SERP.
const title = 'Vé tàu cao tốc Ao Tiên/Vũng Đục Cẩm Phả, Quảng Ninh | Datmo';
const description = 'Đặt vé tàu cao tốc tuyến Ao Tiên/Vũng Đục đi Cô Tô – Quan Lạn; hỗ trợ kiểm tra lịch tàu, giờ chạy, thứ tự và nhờ giữ chỗ có mặt. Hỗ trợ nhờ giữ ra cảng.';
const ogImage = getOgImage('/ve-tau-cao-toc/');
const canonical = SITE.url + '/ve-tau-cao-toc/';

const crumbs = [
  { name: 'Trang chủ', href: '/' },
  { name: 'Vé tàu cao tốc', href: '/ve-tau-cao-toc/' },
];

const faqItems = [
  { q: 'Lịch tàu có cố định không?', a: 'Không. Lịch tàu thay đổi theo mùa và thời tiết. Nên kiểm tra theo ngày bạn đi.' },
  { q: 'Nên đến cảng trước bao lâu?', a: 'Nên có mặt trước giờ chạy tàu ít nhất 30–45 phút để làm thủ tục.' },
];

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Đặt vé tàu cao tốc tại Quảng Ninh',
  areaServed: ['Cẩm Phả', 'Quảng Ninh'],
  provider: { '@type': 'LocalBusiness', name: SITE.name, url: SITE.url, telephone: SITE.phone },
  url: canonical,
};
---
