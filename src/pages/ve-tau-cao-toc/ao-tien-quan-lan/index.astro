---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getOgImage } from '../../../config/og';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FAQ from '../../../components/FAQ.astro';
import JsonLd from '../../../components/JsonLd.astro';
import CallToActions from '../../../components/CallToActions.astro';
import { SITE } from '../../../config/site';

// SEO: tune title/description length for SERP.
const title = 'Vé tŕu Ao Tięn – Quan L?n C?m Ph?, Qu?ng Ninh | Datmo';
const description = 'Đ?t vé tŕu cao t?c Ao Tięn ? Quan L?n; h? tr? ki?m tra l?ch ch?y theo ngŕy, tu v?n gi? có m?t t?i c?ng vŕ gi?y t? c?n thi?t, hu?ng d?n hŕnh lý.';
const ogImage = getOgImage('/ve-tau-cao-toc/ao-tien-quan-lan/');
const canonical = SITE.url + '/ve-tau-cao-toc/ao-tien-quan-lan/';

const crumbs = [
  { name: 'Trang ch?', href: '/' },
  { name: 'Vé tŕu cao t?c', href: '/ve-tau-cao-toc/' },
  { name: 'Vé tŕu cao t?c Ao Tięn ? Quan L?n', href: '/ve-tau-cao-toc/ao-tien-quan-lan/' },
];

const faqItems = [
  { q: 'L?ch tŕu tuy?n nŕy xem ? dâu?', a: 'B?n nęn nh?n Zalo/Hotline d? xác nh?n l?ch ch?y theo ngŕy vŕ th?i ti?t.' },
  { q: 'Có h? tr? xe di c?ng không?', a: 'Có th? k?t h?p thuę xe t? C?m Ph? di c?ng d? k?p gi? tŕu.' },
];

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Vé tŕu cao t?c Ao Tięn ? Quan L?n',
  areaServed: ['C?m Ph?', 'Qu?ng Ninh'],
  provider: { '@type': 'LocalBusiness', name: SITE.name, url: SITE.url, telephone: SITE.phone },
  url: canonical,
};
---
<BaseLayout title={title} description={description} ogImage={ogImage} canonical={canonical} breadcrumb={crumbs}>
  <Breadcrumbs items={crumbs} />

  <section class="container section">
    <h1>Vé tŕu cao t?c Ao Tięn ? Quan L?n</h1>
    <p class="lead">Đ?t vé tŕu cao t?c tuy?n Ao Tięn ? Quan L?n. Tu v?n gi? ch?y, luu ý di l?i vŕ h? tr? d?t vé theo ngŕy b?n di.</p>

    <div class="card">
      <h2>Luu ý quan tr?ng</h2>
      <ul>
        <li>Có m?t tru?c gi? tŕu ch?y 30–45 phút</li>
        <li>Mang gi?y t? tu? thân theo quy d?nh</li>
        <li>L?ch tŕu có th? thay d?i do th?i ti?t</li>
      </ul>
      <p class="small">Xem thęm: <a href="/blog/lich-tau-gia-ve/">Blog l?ch tŕu & giá vé</a> • <a href="/thue-xe-du-lich/">Thuę xe di c?ng</a></p>
    </div>
  </section>

  <FAQ items={faqItems} />
  <JsonLd data={serviceJsonLd} />
  <CallToActions />
</BaseLayout>
