---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getOgImage } from '../../../config/og';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FAQ from '../../../components/FAQ.astro';
import JsonLd from '../../../components/JsonLd.astro';
import CallToActions from '../../../components/CallToActions.astro';
import { SITE } from '../../../config/site';

// SEO: tune title/description length for SERP.
const title = 'Vé tŕu Vung Đ?c – Cô Tô C?m Ph?, Qu?ng Ninh | Datmo';
const description = 'Đ?t vé tŕu cao t?c tuy?n Vung Đ?c ? Cô Tô; phů h?p khách di t? C?m Ph?, h? tr? ki?m tra l?ch tŕu, th? t?c vŕ luu ý an toŕn, tu v?n gi? có m?t t?i c?ng.';
const ogImage = getOgImage('/ve-tau-cao-toc/vung-duc-co-to/');
const canonical = SITE.url + '/ve-tau-cao-toc/vung-duc-co-to/';

const crumbs = [
  { name: 'Trang ch?', href: '/' },
  { name: 'Vé tŕu cao t?c', href: '/ve-tau-cao-toc/' },
  { name: 'Vé tŕu cao t?c Vung Đ?c ? Cô Tô', href: '/ve-tau-cao-toc/vung-duc-co-to/' },
];

const faqItems = [
  { q: 'L?ch tŕu tuy?n nŕy xem ? dâu?', a: 'B?n nęn nh?n Zalo/Hotline d? xác nh?n l?ch ch?y theo ngŕy vŕ th?i ti?t.' },
  { q: 'Có h? tr? xe di c?ng không?', a: 'Có th? k?t h?p thuę xe t? C?m Ph? di c?ng d? k?p gi? tŕu.' },
];

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Vé tŕu cao t?c Vung Đ?c ? Cô Tô',
  areaServed: ['C?m Ph?', 'Qu?ng Ninh'],
  provider: { '@type': 'LocalBusiness', name: SITE.name, url: SITE.url, telephone: SITE.phone },
  url: canonical,
};
---
<BaseLayout title={title} description={description} ogImage={ogImage} canonical={canonical} breadcrumb={crumbs}>
  <Breadcrumbs items={crumbs} />

  <section class="container section">
    <h1>Vé tŕu cao t?c Vung Đ?c ? Cô Tô</h1>
    <p class="lead">Tu v?n/d?t vé tŕu cao t?c tuy?n Vung Đ?c ? Cô Tô (tu? l?ch khai thác). H? tr? ki?m tra l?ch, th?i ti?t vŕ phuong án di chuy?n.</p>

    <div class="card">
      <h2>Luu ý quan tr?ng</h2>
      <ul>
        <li>Có m?t tru?c gi? tŕu ch?y 30–45 phút</li>
        <li>Mang gi?y t? tu? thân theo quy d?nh</li>
        <li>L?ch tŕu có th? thay d?i do th?i ti?t</li>
      </ul>
      <p class="small">Xem thęm: <a href="/blog/lich-tau-gia-ve/">Blog l?ch tŕu & giá vé</a> • <a href="/thue-xe-du-lich/">Thuę xe di c?ng</a></p>
    </div>
  </section>

  <FAQ items={faqItems} />
  <JsonLd data={serviceJsonLd} />
  <CallToActions />
</BaseLayout>
