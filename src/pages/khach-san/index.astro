---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getOgImage } from '../../config/og';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import JsonLd from '../../components/JsonLd.astro';
import CallToActions from '../../components/CallToActions.astro';
import { SITE } from '../../config/site';

// SEO: tune title/description length for SERP.
const title = 'Tu v?n d?t phňng khách s?n C?m Ph?, Qu?ng Ninh | Datmo';
const description = 'Tu v?n & d?t phňng khách s?n cho khách C?m Ph?/Qu?ng Ninh theo nhu c?u v? trí, ngân sách, ti?n ích; có th? k?t h?p tour ho?c vé máy bay. H? tr? nhanh.';
const ogImage = getOgImage('/khach-san/');
const canonical = SITE.url + '/khach-san/';

const crumbs = [
  { name: 'Trang ch?', href: '/' },
  { name: 'Đ?t phňng khách s?n t?i Qu?ng Ninh', href: '/khach-san/' },
];

const faqItems = [
  { q: 'C?n cung c?p thông tin gě d? d?t nhanh?', a: 'H? tęn, ngŕy di (kh? h?i n?u có), tuy?n/di?m d?n vŕ s? di?n tho?i lięn h?.' },
  { q: 'Có h? tr? thay d?i/hoŕn hu? không?', a: 'Tu? di?u ki?n c?a hăng/nhŕ cung c?p. Datmo h? tr? hu?ng d?n vŕ x? lý theo quy d?nh.' },
];

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Đ?t phňng khách s?n t?i Qu?ng Ninh',
  areaServed: ['C?m Ph?', 'Qu?ng Ninh'],
  provider: { '@type': 'LocalBusiness', name: SITE.name, url: SITE.url, telephone: SITE.phone },
  url: canonical,
};
---
<BaseLayout title={title} description={description} ogImage={ogImage} canonical={canonical} breadcrumb={crumbs}>
  <Breadcrumbs items={crumbs} />
  <section class="container section">
    <h1>Đ?t phňng khách s?n t?i Qu?ng Ninh</h1>
    <p class="lead">Tu v?n & d?t phňng khách s?n cho khách C?m Ph?/Qu?ng Ninh theo nhu c?u v? trí, ngân sách, ti?n ích. Có th? k?t h?p tour vŕ vé máy bay.</p>

    <div class="card">
      <h2>Lięn k?t cůng SILO</h2>
      <ul class="link-list">
        <li><a href="/ve-may-bay/">Vé máy bay</a></li><li><a href="/tour-du-lich/">Tour du l?ch</a></li><li><a href="/thue-xe-du-lich/">Thuę xe du l?ch</a></li>
      </ul>
    </div>
  </section>

  <FAQ items={faqItems} />
  <JsonLd data={serviceJsonLd} />
  <CallToActions />
</BaseLayout>
