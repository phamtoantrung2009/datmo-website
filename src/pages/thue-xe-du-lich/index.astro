---
import BaseLayout from '../../layouts/BaseLayout.astro';



import { getOgImage } from '../../config/og';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import JsonLd from '../../components/JsonLd.astro';
import { SITE } from '../../config/site';
import QuoteForm from '../../components/QuoteForm.astro';

// SEO: tune title/description length for SERP.
const title = 'Thuę xe du l?ch 16–45 ch? C?m Ph?, Qu?ng Ninh | Datmo';
const description = 'D?ch v? thuę xe du l?ch 16–45 ch? t?i C?m Ph?: nh?n tuy?n H? Long, Vân Đ?n/Ao Tięn, Móng Cái, dua dón sân bay N?i Bŕi. Tu v?n nhanh, giá rő.';
const ogImage = getOgImage('/thue-xe-du-lich/');
const canonical = SITE.url + '/thue-xe-du-lich/';

const crumbs = [
  { name: 'Trang ch?', href: '/' },
  { name: 'Thuę xe du l?ch', href: '/thue-xe-du-lich/' },
];

const faqItems = [
  { q: 'Datmo có nh?ng lo?i xe nŕo?', a: 'T?p trung xe 16 ch?, 29 ch? vŕ 45 ch? ph?c v? nhóm gia děnh, công ty, tour doŕn.' },
  { q: 'Có nh?n dua dón Ao Tięn/Vung Đ?c không?', a: 'Có. B?n có th? d?t xe di c?ng Ao Tięn (Vân Đ?n) ho?c Vung Đ?c (C?m Ph?) d? k?p gi? tŕu.' },
];

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Thuę xe du l?ch 16–45 ch? t?i C?m Ph?',
  areaServed: ['C?m Ph?', 'Qu?ng Ninh'],
  provider: { '@type': 'LocalBusiness', name: SITE.name, url: SITE.url, telephone: SITE.phone },
  url: canonical,
};
---
<BaseLayout title={title} description={description} ogImage={ogImage} canonical={canonical} breadcrumb={crumbs}>
  <Breadcrumbs items={crumbs} />

  <section class="container section">
    <h1>Thuę xe du l?ch 16 – 45 ch? t?i C?m Ph?</h1>
    <p class="lead">Xe phů h?p di công tác, gia děnh, tour doŕn. Tu v?n tuy?n di trong Qu?ng Ninh vŕ lięn t?nh.</p>
  <section class="container section">
    <QuoteForm />
  </section>
    <div class="grid-3">
      <a class="card" href="/thue-xe-du-lich/thue-xe-16-cho-cam-pha/"><h3>Thuę xe 16 ch?</h3><p>Đi H? Long, Ao Tięn, N?i Bŕi…</p></a>
      <a class="card" href="/thue-xe-du-lich/thue-xe-29-cho-cam-pha/"><h3>Thuę xe 29 ch?</h3><p>Nhóm công ty, s? ki?n, tour doŕn</p></a>
      <a class="card" href="/thue-xe-du-lich/thue-xe-45-cho-cam-pha/"><h3>Thuę xe 45 ch?</h3><p>Đoŕn dông, l?ch trěnh dŕi ngŕy</p></a>
    </div>

    <div class="card" style="margin-top:14px">
      <h2>Lięn k?t cůng SILO</h2>
      <ul class="link-list">
        <li><a href="/ve-tau-cao-toc/">K?t h?p d?t vé tŕu cao t?c di Cô Tô/Quan L?n</a></li>
        <li><a href="/tour-du-lich/">G?i ý tour xu?t phát t? C?m Ph?</a></li>
      </ul>
    </div>
  </section>

  <FAQ items={faqItems} />
  <JsonLd data={serviceJsonLd} />
</BaseLayout>
