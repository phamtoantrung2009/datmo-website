---
import BaseLayout from '../../../layouts/BaseLayout.astro';



import { getOgImage } from '../../../config/og';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FAQ from '../../../components/FAQ.astro';
import JsonLd from '../../../components/JsonLd.astro';
import CallToActions from '../../../components/CallToActions.astro';
import { SITE } from '../../../config/site';
import QuoteForm from '../../../components/QuoteForm.astro';

// SEO: tune title/description length for SERP.
const title = 'Thuę xe du l?ch 45 ch? C?m Ph?, Qu?ng Ninh | Datmo';
const description = 'Thuę xe 45 ch? ph?c v? doŕn dông, l?ch trěnh dŕi ngŕy; h? tr? tuy?n Qu?ng Ninh, Hŕ N?i, sân bay N?i Bŕi, c?ng Ao Tięn. Tu v?n nhanh, xe d?i m?i.';
const ogImage = getOgImage('/thue-xe-du-lich/thue-xe-45-cho-cam-pha/');
const canonical = SITE.url + '/thue-xe-du-lich/thue-xe-45-cho-cam-pha/';

const crumbs = [
  { name: 'Trang ch?', href: '/' },
  { name: 'Thuę xe du l?ch', href: '/thue-xe-du-lich/' },
  { name: 'Thuę xe 45 ch? t?i C?m Ph?', href: '/thue-xe-du-lich/thue-xe-45-cho-cam-pha/' },
];

const faqItems = [
  { q: 'C?n d?t xe tru?c bao lâu?', a: 'Nęn d?t tru?c 1–3 ngŕy; cu?i tu?n/l? nęn d?t s?m hon d? gi? l?ch.' },
  { q: 'Có h? tr? di c?ng/tŕu không?', a: 'Có. B?n có th? d?t xe di Ao Tięn/Vung Đ?c d? k?p gi? tŕu.' },
];

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Thuę xe 45 ch? t?i C?m Ph?',
  areaServed: ['C?m Ph?', 'Qu?ng Ninh'],
  provider: { '@type': 'LocalBusiness', name: SITE.name, url: SITE.url, telephone: SITE.phone },
  url: canonical,
};
---

<BaseLayout title={title} description={description} ogImage={ogImage} canonical={canonical} breadcrumb={crumbs}>
  <Breadcrumbs items={crumbs} />

  <header class="container section">
    <h1>Thuę xe 45 ch? t?i C?m Ph?</h1>
    <p class="lead">D?ch v? phů h?p nhóm di theo tuy?n, theo ngŕy ho?c theo l?ch trěnh tour. Báo giá nhanh qua hotline/Zalo.</p>
<section class="container section">
    <QuoteForm />
  </section>
    <div class="btn-row">
      <a class="btn primary" href="/lien-he/">Đ?t d?ch v?</a>
      <a class="btn" href="/thue-xe-du-lich/">Xem các lo?i xe</a><a class="btn" href="/tour-du-lich/">Xem tour</a>
    </div>
  </header>

  <section class="container section">
    <h2>Tuy?n ph? bi?n</h2>
    <ul>
      <li>C?m Ph? ? H? Long</li>
      <li>C?m Ph? ? Vân Đ?n/Ao Tięn (di tŕu ra d?o)</li>
      <li>C?m Ph? ? N?i Bŕi (dua dón sân bay)</li>
    </ul>
  </section>

  <FAQ items={faqItems} />
  <JsonLd data={serviceJsonLd} />
  <CallToActions />
</BaseLayout>
