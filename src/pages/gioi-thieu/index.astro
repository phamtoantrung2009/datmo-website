---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getOgImage } from '../../config/og';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

// SEO: tune title/description length for SERP.
const title = 'Gi?i thi?u Datmo – d?ch v? C?m Ph?, Qu?ng Ninh | Datmo';
const description = 'Datmo cung c?p d?ch v? du l?ch & v?n chuy?n t?i C?m Ph?: thuê xe 16–45 ch?, tour, vé tàu cao t?c, vé máy bay, khách s?n, visa. H? tr? nhanh qua hotline/Zalo.';
const ogImage = getOgImage('/gioi-thieu/');
const crumbs = [
  { name: 'Trang ch?', href: '/' },
  { name: 'Gi?i thi?u', href: '/gioi-thieu/' },
];
---
<BaseLayout title={title} description={description} ogImage={ogImage} breadcrumb={crumbs}>
  <Breadcrumbs items={crumbs} />
  <section class="container section">
    <h1>Gi?i thi?u Datmo.io.vn</h1>
    <p class="lead">Website n?i dung – d?ch v? d?a phuong cho khách t?i C?m Ph?, Qu?ng Ninh.</p>
    <div class="grid-2">
      <div class="card">
        <h2>M?c tiêu</h2>
        <p class="small">Cung c?p gi?i pháp d?t d?ch v? nhanh: thuê xe, tour, vé tàu, vé máy bay, khách s?n, visa – h? chi?u.</p>
      </div>
      <div class="card">
        <h2>Ph?m vi</h2>
        <p class="small">T?p trung C?m Ph? và các tuy?n ph? bi?n trong t?nh Qu?ng Ninh, k?t n?i c?ng Ao Tiên/Vung Ð?c.</p>
      </div>
    </div>
  </section>
</BaseLayout>
