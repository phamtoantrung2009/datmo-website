---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getOgImage } from '../../../config/og';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

// SEO: tune title/description length for SERP.
const title = 'L?ch t‡u & gi· vÈ Ao TiÍn, Vung –?c C?m Ph? | Blog Datmo';
const description = 'C?p nh?t l?ch t‡u cao t?c, gi· vÈ Ao TiÍn ñ CÙ TÙ, Ao TiÍn ñ Quan L?n; kËm luu ˝ d?t vÈ, gi? ch?y theo ng‡y v‡ tÏnh hÏnh th?i ti?t, th? t?c.';
const ogImage = getOgImage('/blog/lich-tau-gia-ve/');
const crumbs = [
  { name: 'Trang ch?', href: '/' },
  { name: 'Blog', href: '/blog/' },
  { name: 'L?ch t‡u & gi· vÈ', href: '/blog/lich-tau-gia-ve/' },
];

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.category === 'lich-tau-gia-ve'))
  .sort((a, b) => +new Date(b.data.publishedAt) - +new Date(a.data.publishedAt));
---
<BaseLayout title={title} description={description} ogImage={ogImage} breadcrumb={crumbs}>
  <Breadcrumbs items={crumbs} />
  <section class="container section">
    <h1>L?ch t‡u & gi· vÈ</h1>
    <p class="lead">B‡i vi?t t?p trung thÙng tin l?ch t‡u/gi· vÈ v‡ luu ˝ d?t vÈ.</p>
    <div class="grid-2">
      {posts.map((p) => (
        <a class="card post-card" href={`/blog/${p.slug}/`}>
          <h3>{p.data.title}</h3>
          <div class="blog-meta">{new Date(p.data.publishedAt).toLocaleDateString('vi-VN')}</div>
          <p class="small">{p.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
