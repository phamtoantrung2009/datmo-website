---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getOgImage } from '../../../config/og';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
    .sort((a, b) => +new Date(b.data.publishedAt) - +new Date(a.data.publishedAt));
  
  const pageSize = 8;
  const totalPages = Math.ceil(allPosts.length / pageSize);
  
  return Array.from({ length: totalPages - 1 }, (_, i) => {
    const pageNum = i + 2;
    const start = (pageNum - 1) * pageSize;
    return {
      params: { page: String(pageNum) },
      props: { pageNum, posts: allPosts.slice(start, start + pageSize), total: allPosts.length, totalPages }
    };
  });
}

const { pageNum, posts, total, totalPages } = Astro.props;

const title = `Blog - Trang ${pageNum} | Datmo`;
const description = 'Chia sẻ lịch tàu, giá vé, tin tức Cẩm Phả và kinh nghiệm du lịch; nội dung ngắn gọn, cập nhật theo mùa và nhu cầu thực tế cho khách đi Quảng Ninh.';
const ogImage = getOgImage('/blog/');

const crumbs = [
  { name: 'Trang chủ', href: '/' },
  { name: 'Blog', href: '/blog/' },
  { name: `Trang ${pageNum}`, href: `/blog/page/${pageNum}/` },
];
---
<BaseLayout title={title} description={description} ogImage={ogImage}>
  <Breadcrumbs items={crumbs} />

  <section class="container section">
    <h1>Blog - Trang {pageNum}</h1>
    <p class="lead">Nội dung cập nhật theo mùa: lịch tàu, kinh nghiệm thuê xe, mẹo đi lại tại Quảng Ninh.</p>

    <div class="grid-3" style="margin-bottom:24px">
      <a class="card" href="/blog/kinh-nghiem-du-lich/"><h3>Kinh nghiệm du lịch</h3><p>Tips & lịch trình</p></a>
      <a class="card" href="/blog/tin-tuc-cam-pha/"><h3>Tin tức Cẩm Phả</h3><p>Điểm đến, sự kiện</p></a>
      <a class="card" href="/blog/lich-tau-gia-ve/"><h3>Lịch tàu & giá vé</h3><p>Ao Tiên, Quan Lạn, Cô Tô</p></a>
      <a class="card" href="/blog/cho-thue-xe/"><h3>Cho thuê xe</h3><p>Bảng giá, tuyến đường</p></a>
      <a class="card" href="/blog/ve-tau-cao-toc/"><h3>Vé tàu cao tốc</h3><p>Lịch tàu, đặt vé</p></a>
      <a class="card" href="/blog/ve-may-bay/"><h3>Vé máy bay</h3><p>Săn vé rẻ, combo</p></a>
    </div>

    <h2 style="margin-top:26px">Bài viết ({total})</h2>
    <div class="grid-2">
      {posts.map((p) => (
        <a class="card post-card" href={`/blog/${p.slug}/`}>
          <h3>{p.data.title}</h3>
          <div class="blog-meta">
            <span>{new Date(p.data.publishedAt).toLocaleDateString('vi-VN')}</span>
            <span> • </span>
            <span>{p.data.category}</span>
          </div>
          <p class="small">{p.data.description}</p>
        </a>
      ))}
    </div>

    <nav class="pagination" style="margin-top:32px; display:flex; justify-content:center; gap:8px; flex-wrap:wrap; align-items:center">
      <a href="/blog/" class="page-btn">← Trang trước</a>
      <a href="/blog/" class="page-num">1</a>
      {Array.from({ length: totalPages - 1 }, (_, i) => i + 2).map((pn) => (
        <a 
          href={pn === pageNum ? '#' : (pn === pageNum - 1 ? '/blog/' : `/blog/page/${pn}/`)}
          class:list={['page-num', { active: pn === pageNum }]}
        >
          {pn}
        </a>
      ))}
      {pageNum < totalPages && (
        <a href={`/blog/page/${pageNum + 1}/`} class="page-btn">Trang sau →</a>
      )}
    </nav>

    <h3 style="margin-top:40px; margin-bottom:16px">Danh sách tất cả bài viết</h3>
    <div class="short-list">
      {(await getCollection('blog', ({ data }) => !data.draft))
        .sort((a, b) => +new Date(b.data.publishedAt) - +new Date(a.data.publishedAt))
        .map((p, i) => (
          <a href={`/blog/${p.slug}/`} class="short-item">
            <span class="short-num">{i + 1}.</span>
            <span class="short-title">{p.data.title}</span>
            <span class="short-date">{new Date(p.data.publishedAt).toLocaleDateString('vi-VN')}</span>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .pagination { gap: 6px; }
  .page-btn {
    padding: 10px 16px;
    background: #0f2a44;
    color: #fff !important;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 500;
    font-size: 14px;
  }
  .page-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    height: 36px;
    padding: 0 10px;
    background: #e8eef4;
    color: #0f2a44;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 500;
    font-size: 14px;
  }
  .page-num.active {
    background: #0f2a44;
    color: #fff !important;
  }
  .short-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 4px;
  }
  .short-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 12px;
    border-radius: 8px;
    text-decoration: none;
  }
  .short-item:hover { background: #f0f7fb; }
  .short-num { color: var(--muted); font-size: 13px; min-width: 24px; }
  .short-title { flex: 1; color: var(--text); font-size: 14px; font-weight: 500; }
  .short-date { color: var(--muted); font-size: 12px; }
</style>
