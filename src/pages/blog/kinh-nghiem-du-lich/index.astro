---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getOgImage } from '../../../config/og';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

// SEO: tune title/description length for SERP.
const title = 'Kinh nghi?m du l?ch th?c t? C?m Ph?, Qu?ng Ninh | Blog Datmo';
const description = 'Kinh nghi?m, l?ch tŕnh, m?o di chuy?n và chi phí cho khách di C?m Ph?, Qu?ng Ninh; c?p nh?t theo mùa, kèm g?i ư l?ch tŕnh t?i uu và luu ư d?t d?ch v?.';
const ogImage = getOgImage('/blog/kinh-nghiem-du-lich/');
const crumbs = [
  { name: 'Trang ch?', href: '/' },
  { name: 'Blog', href: '/blog/' },
  { name: 'Kinh nghi?m du l?ch', href: '/blog/kinh-nghiem-du-lich/' },
];

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.category === 'kinh-nghiem-du-lich'))
  .sort((a, b) => +new Date(b.data.publishedAt) - +new Date(a.data.publishedAt));
---
<BaseLayout title={title} description={description} ogImage={ogImage} breadcrumb={crumbs}>
  <Breadcrumbs items={crumbs} />
  <section class="container section">
    <h1>Kinh nghi?m du l?ch</h1>
    <p class="lead">T?ng h?p bài vi?t kinh nghi?m, tips & l?ch tŕnh.</p>
    <div class="grid-2">
      {posts.map((p) => (
        <a class="card post-card" href={`/blog/${p.slug}/`}>
          <h3>{p.data.title}</h3>
          <div class="blog-meta">{new Date(p.data.publishedAt).toLocaleDateString('vi-VN')}</div>
          <p class="small">{p.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
