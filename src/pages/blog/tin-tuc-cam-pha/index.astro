---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getOgImage } from '../../../config/og';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

// SEO: tune title/description length for SERP.
const title = 'Tin t?c du l?ch m?i C?m Ph?, Qu?ng Ninh | Blog Datmo';
const description = 'T?ng h?p tin t?c di?m d?n, s? ki?n vŕ d?ch v? t?i C?m Ph?; giúp b?n lęn k? ho?ch nhanh, sát th?c t? vŕ ti?t ki?m th?i gian, chi phí khi di Qu?ng Ninh.';
const ogImage = getOgImage('/blog/tin-tuc-cam-pha/');
const crumbs = [
  { name: 'Trang ch?', href: '/' },
  { name: 'Blog', href: '/blog/' },
  { name: 'Tin t?c C?m Ph?', href: '/blog/tin-tuc-cam-pha/' },
];

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.category === 'tin-tuc-cam-pha'))
  .sort((a, b) => +new Date(b.data.publishedAt) - +new Date(a.data.publishedAt));
---
<BaseLayout title={title} description={description} ogImage={ogImage} breadcrumb={crumbs}>
  <Breadcrumbs items={crumbs} />
  <section class="container section">
    <h1>Tin t?c C?m Ph?</h1>
    <p class="lead">C?p nh?t di?m d?n, s? ki?n, thông tin di chuy?n.</p>
    <div class="grid-2">
      {posts.map((p) => (
        <a class="card post-card" href={`/blog/${p.slug}/`}>
          <h3>{p.data.title}</h3>
          <div class="blog-meta">{new Date(p.data.publishedAt).toLocaleDateString('vi-VN')}</div>
          <p class="small">{p.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
