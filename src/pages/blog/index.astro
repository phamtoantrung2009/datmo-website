---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Pagination from '../../components/Pagination.astro';
import { getCollection } from 'astro:content';

const POSTS_PER_PAGE = 8;

// Get all posts
const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => +new Date(b.data.publishedAt) - +new Date(a.data.publishedAt));

const totalPosts = allPosts.length;
const totalPages = Math.ceil(totalPosts / POSTS_PER_PAGE);

// Main index shows first page
const currentPage = 1;
const posts = allPosts.slice(0, POSTS_PER_PAGE);

const title = 'Blog du lịch Cẩm Phả – Quảng Ninh | Datmo';
const description = 'Blog chia sẻ lịch tàu, giá vé, tin tức Cẩm Phả và kinh nghiệm du lịch. Tập trung nội dung hữu ích cho khách tại Quảng Ninh.';

const crumbs = [
  { name: 'Trang chủ', href: '/' },
  { name: 'Blog', href: '/blog/' },
];
---
<BaseLayout title={title} description={description} breadcrumb={crumbs}>
  <Breadcrumbs items={crumbs} />

  <section class="container section">
    <h1>Blog</h1>
    <p class="lead">Nội dung cập nhật theo mùa: lịch tàu, kinh nghiệm thuê xe, mẹo đi lại tại Quảng Ninh.</p>

    <div class="grid-3" style="margin-bottom:24px">
      <a class="card" href="/blog/kinh-nghiem-du-lich/"><h3>Kinh nghiệm du lịch</h3><p>Tips & lịch trình</p></a>
      <a class="card" href="/blog/tin-tuc-cam-pha/"><h3>Tin tức Cẩm Phả</h3><p>Điểm đến, sự kiện</p></a>
      <a class="card" href="/blog/lich-tau-gia-ve/"><h3>Lịch tàu & giá vé</h3><p>Ao Tiên, Quan Lạn, Cô Tô</p></a>
      <a class="card" href="/blog/cho-thue-xe/"><h3>Cho thuê xe</h3><p>Bảng giá, tuyến đường</p></a>
      <a class="card" href="/blog/ve-tau-cao-toc/"><h3>Vé tàu cao tốc</h3><p>Lịch tàu, đặt vé</p></a>
      <a class="card" href="/blog/ve-may-bay/"><h3>Vé máy bay</h3><p>Săn vé rẻ, combo</p></a>
    </div>

    <h2 style="margin-top:26px">Bài mới nhất ({totalPosts} bài)</h2>
    <div class="grid-2">
      {posts.map((p) => (
        <a class="card post-card" href={`/blog/${p.slug}/`}>
          <h3>{p.data.title}</h3>
          <div class="blog-meta">
            <span>{new Date(p.data.publishedAt).toLocaleDateString('vi-VN')}</span>
            <span> • </span>
            <span>{p.data.category}</span>
          </div>
          <p class="small">{p.data.description}</p>
        </a>
      ))}
    </div>

    {/* Pagination */}
    {totalPages > 1 && (
      <Pagination currentPage={currentPage} totalPages={totalPages} baseUrl="/blog" />
    )}

    {/* Archive link */}
    {totalPosts > POSTS_PER_PAGE && (
      <div style="margin-top:24px; text-align:center">
        <a href="/blog/archive/" class="btn" style="display:inline-flex;align-items:center;gap:8px">
          📚 Xem tất cả {totalPosts} bài viết
        </a>
      </div>
    )}
  </section>
</BaseLayout>
